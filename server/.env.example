# ==============================================
# ResumeAI Backend Environment Configuration
# ==============================================
# Copy this file to .env and update with your values
# NEVER commit .env to version control!

# ----------------------------------------------
# Server Configuration
# ----------------------------------------------
NODE_ENV=development
PORT=5000

# ----------------------------------------------
# Database Configuration
# ----------------------------------------------
# Local MongoDB
MONGO_URI=mongodb://localhost:27017/resumeai

# MongoDB Atlas (Cloud)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/resumeai?retryWrites=true&w=majority

# Database Options
MONGO_OPTIONS={}

# ----------------------------------------------
# JWT Authentication
# ----------------------------------------------
# Generate a secure random string (at least 32 characters)
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ----------------------------------------------
# Google Gemini AI
# ----------------------------------------------
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Model Configuration
GEMINI_MODEL_FLASH=gemini-1.5-flash
GEMINI_MODEL_PRO=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# AI Configuration
AI_MAX_TOKENS=8192
AI_TEMPERATURE=0.7

# ----------------------------------------------
# Email Configuration
# ----------------------------------------------
# Gmail SMTP Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password
EMAIL_FROM=ResumeAI <noreply@resumeai.com>

# Email Templates
EMAIL_RESET_SUBJECT=Password Reset Request
EMAIL_WELCOME_SUBJECT=Welcome to ResumeAI

# ----------------------------------------------
# Frontend URL (for CORS and email links)
# ----------------------------------------------
CLIENT_URL=http://localhost:3002
FRONTEND_RESET_URL=http://localhost:3002/reset-password

# ----------------------------------------------
# File Upload Configuration
# ----------------------------------------------
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_PATH=./uploads

# ----------------------------------------------
# Rate Limiting
# ----------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Rate Limits (per endpoint type)
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_AI_MAX=20

# ----------------------------------------------
# Security
# ----------------------------------------------
# CORS Origins (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3002,http://localhost:3000

# Bcrypt Salt Rounds
BCRYPT_SALT_ROUNDS=10

# ----------------------------------------------
# Logging
# ----------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=combined

# ----------------------------------------------
# Session Configuration
# ----------------------------------------------
SESSION_SECRET=your_session_secret_change_this
SESSION_EXPIRE=86400000

# ----------------------------------------------
# Feature Flags
# ----------------------------------------------
ENABLE_EMAIL=true
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true
ENABLE_COMPRESSION=true

# ----------------------------------------------
# Development Only
# ----------------------------------------------
# Set to true to see detailed error messages
DEBUG_MODE=false
SHOW_STACK_TRACE=false

# Seed database with test data
SEED_DATABASE=false
