  "analysisSuccessRate": {
    "endpoint": "GET /api/dashboard/charts/success-rate?days=30",
    "description": "Analysis success rate over time (line chart)",
    "response": {
      "success": true,
      "message": "Analysis success rate retrieved successfully",
      "data": {
        "labels": ["2026-06-15", "2026-06-16", "2026-06-18", "2026-06-20"],
        "datasets": [
          {
            "label": "Success Rate (%)",
            "data": [100, 75, 100, 100]
          }
