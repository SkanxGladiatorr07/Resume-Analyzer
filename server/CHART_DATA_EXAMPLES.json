  "allCharts": {
    "endpoint": "GET /api/dashboard/charts?days=30&topSkills=10&topMissingSkills=10",
    "description": "All chart data in one request (for dashboard page load)",
    "response": {
      "success": true,
      "message": "Chart data retrieved successfully",
      "data": {
        "atsScoreTrend": "{ ... see atsScoreTrend above ... }",
        "resumeUploadTimeline": "{ ... see resumeUploadTimeline above ... }",
        "skillsDistribution": "{ ... see skillsDistribution above ... }",
        "jobMatchScoreDistribution": "{ ... see jobMatchScoreDistribution above ... }",
        "resumeCompletenessScore": "{ ... see resumeCompletenessScore above ... }",
        "mostCommonMissingSkills": "{ ... see mostCommonMissingSkills above ... }",
        "atsScoreDistribution": "{ ... see atsScoreDistribution above ... }",
        "analysisSuccessRate": "{ ... see analysisSuccessRate above ... }",
        "metadata": {
          "generatedAt": "2026-07-14T12:00:00.000Z",
          "userId": "...",
          "options": {
            "days": 30,
            "topSkills": 10,
            "topMissingSkills": 10
          }
        }
      }
    },
    "usage": "Load all charts at once for dashboard, then cache on frontend"
  },

  "frontendUsage": {
    "description": "How to use this data in frontend charting libraries",
    "examples": {
      "ChartJS": {
        "lineChart": {
          "code": "new Chart(ctx, { type: 'line', data: response.data })"
        },
        "barChart": {
          "code": "new Chart(ctx, { type: 'bar', data: response.data })"
        },
        "pieChart": {
          "code": "new Chart(ctx, { type: 'pie', data: { labels: response.data.labels, datasets: [...] } })"
        }
      },
      "Recharts": {
        "lineChart": {
          "code": "<LineChart data={response.data.raw}><Line dataKey='averageScore' /></LineChart>"
        },
        "barChart": {
          "code": "<BarChart data={response.data.raw}><Bar dataKey='count' /></BarChart>"
        }
      },
      "ApexCharts": {
        "lineChart": {
          "code": "{ series: response.data.datasets, xaxis: { categories: response.data.labels } }"
        }
      }
    }
  },

  "notes": {
    "dataFormat": "All endpoints return both 'labels/datasets' format (for Chart.js) and 'raw' format (for Recharts/custom charts)",
    "authentication": "All endpoints require JWT token in Authorization header",
    "caching": "Frontend should cache chart data for 30-60 seconds to reduce API calls",
    "emptyData": "If no data exists, arrays will be empty []",
    "nullValues": "Average scores return null if no completed items exist"
  }
}
