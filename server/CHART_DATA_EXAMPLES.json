{
  "description": "Example responses for chart endpoints - Frontend-ready JSON format",
  
  "atsScoreTrend": {
    "endpoint": "GET /api/dashboard/charts/ats-trend?days=30",
    "description": "ATS score trend over time (line chart)",
    "response": {
      "success": true,
      "message": "ATS score trend retrieved successfully",
      "data": {
        "labels": ["2026-06-15", "2026-06-16", "2026-06-18", "2026-06-20"],
        "datasets": [
          {
            "label": "Average ATS Score",
            "data": [72, 78, 85, 82]
          }
        ],
        "raw": [
          { "date": "2026-06-15", "averageScore": 72, "count": 2 },
          { "date": "2026-06-16", "averageScore": 78, "count": 1 },
          { "date": "2026-06-18", "averageScore": 85, "count": 3 },
          { "date": "2026-06-20", "averageScore": 82, "count": 1 }
        ]
      }
    },
    "chartType": "Line Chart",
    "usage": "Shows progression of ATS scores over time to track improvement"
  },

  "resumeUploadTimeline": {
    "endpoint": "GET /api/dashboard/charts/upload-timeline?days=30",
    "description": "Resume upload activity over time (multi-line or stacked bar chart)",
    "response": {
      "success": true,
      "message": "Resume upload timeline retrieved successfully",
      "data": {
        "labels": ["2026-06-15", "2026-06-17", "2026-06-20"],
        "datasets": [
          {
            "label": "Total Uploads",
            "data": [3, 2, 4]
          },
          {
            "label": "Completed",
            "data": [3, 1, 4]
          },
          {
            "label": "Failed",
            "data": [0, 1, 0]
          }
        ],
        "raw": [
          { "date": "2026-06-15", "total": 3, "completed": 3, "failed": 0 },
          { "date": "2026-06-17", "total": 2, "completed": 1, "failed": 1 },
          { "date": "2026-06-20", "total": 4, "completed": 4, "failed": 0 }
        ]
      }
    },
    "chartType": "Stacked Bar Chart or Multi-line Chart",
    "usage": "Shows upload activity and success/failure rates over time"
  },

