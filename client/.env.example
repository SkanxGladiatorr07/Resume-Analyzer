# ==============================================
# ResumeAI Frontend Environment Configuration
# ==============================================
# Copy this file to .env and update with your values
# NEVER commit .env to version control!

# ----------------------------------------------
# API Configuration
# ----------------------------------------------
# Backend API URL (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# API Request Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# API Retry Configuration
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000

# ----------------------------------------------
# Application Configuration
# ----------------------------------------------
VITE_APP_NAME=ResumeAI
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-Powered Resume Analysis Platform

# Application URLs
VITE_APP_URL=http://localhost:3002
VITE_API_BASE_URL=http://localhost:5000

# ----------------------------------------------
# Feature Flags
# ----------------------------------------------
# Enable/disable features (true/false)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_CAREER_ASSISTANT=true
VITE_ENABLE_JOB_MATCH=true
VITE_ENABLE_DARK_MODE=false

# Beta Features
VITE_ENABLE_RESUME_TEMPLATES=false
VITE_ENABLE_COVER_LETTER=false
VITE_ENABLE_INTERVIEW_PREP=false

# ----------------------------------------------
# File Upload Configuration
# ----------------------------------------------
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES=.pdf,.docx
VITE_UPLOAD_CHUNK_SIZE=1048576

# ----------------------------------------------
# UI Configuration
# ----------------------------------------------
# Theme
VITE_DEFAULT_THEME=light
VITE_ENABLE_THEME_SWITCHER=true

# Pagination
VITE_DEFAULT_PAGE_SIZE=10
VITE_MAX_PAGE_SIZE=100

# Charts
VITE_CHART_ANIMATION_DURATION=1000
VITE_ENABLE_CHART_ANIMATIONS=true

# ----------------------------------------------
# Authentication Configuration
# ----------------------------------------------
# Token storage key (localStorage)
VITE_AUTH_TOKEN_KEY=resumeai_token
VITE_AUTH_USER_KEY=resumeai_user

# Auto logout after inactivity (milliseconds)
VITE_AUTO_LOGOUT_TIME=3600000

# ----------------------------------------------
# Analytics & Monitoring (Optional)
# ----------------------------------------------
# Google Analytics
VITE_GA_TRACKING_ID=

# Sentry Error Tracking
VITE_SENTRY_DSN=

# ----------------------------------------------
# External Services (Optional)
# ----------------------------------------------
# LinkedIn OAuth (if implemented)
VITE_LINKEDIN_CLIENT_ID=

# Google OAuth (if implemented)
VITE_GOOGLE_CLIENT_ID=

# ----------------------------------------------
# Development Configuration
# ----------------------------------------------
# Show debug information in console
VITE_DEBUG=false

# Enable React DevTools in production
VITE_ENABLE_DEVTOOLS=false

# Mock API responses for testing
VITE_USE_MOCK_API=false

# ----------------------------------------------
# Performance Configuration
# ----------------------------------------------
# Enable service worker for PWA
VITE_ENABLE_SERVICE_WORKER=false

# Enable code splitting
VITE_ENABLE_CODE_SPLITTING=true

# Lazy load images
VITE_LAZY_LOAD_IMAGES=true

# ----------------------------------------------
# SEO Configuration (for production)
# ----------------------------------------------
VITE_SEO_TITLE=ResumeAI - AI-Powered Resume Analysis
VITE_SEO_DESCRIPTION=Transform your resume with intelligent AI analysis and optimization
VITE_SEO_KEYWORDS=resume,ats,ai,job,career,analysis

# ----------------------------------------------
# Social Media (for sharing)
# ----------------------------------------------
VITE_TWITTER_HANDLE=@resumeai
VITE_FACEBOOK_APP_ID=
VITE_OG_IMAGE_URL=

# ----------------------------------------------
# Contact & Support
# ----------------------------------------------
VITE_SUPPORT_EMAIL=support@resumeai.com
VITE_CONTACT_URL=https://resumeai.com/contact

# ----------------------------------------------
# Legal
# ----------------------------------------------
VITE_PRIVACY_POLICY_URL=https://resumeai.com/privacy
VITE_TERMS_OF_SERVICE_URL=https://resumeai.com/terms
